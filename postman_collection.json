				{
					"name": "Create Deposit",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Transaction is DEPOSIT type\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.type).to.eql('DEPOSIT');",
									"});",
									"",
									"pm.test(\"Balance increased\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.balanceAfter).to.be.above(0);",
									"});",
									"",
									"// Save transaction ID",
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"transactionId\", jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
